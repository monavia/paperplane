# === DISCORD ===
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
PREFIX=-
DEPLOY_COMMANDS=true
TRIGGER=seryn

# === DATABASE ===
MONGO_URI=mongodb://localhost:27017/paperplane

# === AI (optional) ===
# Falls back to OPENROUTER_API_KEY / OPENROUTER_MODEL if AI_* unset.
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=your_ai_api_key_here
AI_MODEL=qwen2.5:7b
# AI_TEMPERATURE=0.7
# AI_MAX_TOKENS=2048

# === LAVALINK ===
# Node 1
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false
LAVALINK_REGION=asia

# Node 2 (optional)
# LAVALINK_HOST_2=...
# LAVALINK_PORT_2=2334
# LAVALINK_PASSWORD_2=...

# === API ===
API_PORT=3001
# API_HOST=0.0.0.0
# BOT_API_TOKEN=your_shared_token

# === AUTH (optional — for dashboard integration) ===
# NEXTAUTH_SECRET=your_secret
# TRUSTED_IPS=127.0.0.1
# NEXT_PUBLIC_ADMIN_DISCORD_IDS=111111111111111111,222222222222222222
