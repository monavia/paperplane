{
  "name": "paperplane-single",
  "version": "2.0.0",
  "description": "Paperplane bot — single node",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop paperplane",
    "pm2:restart": "pm2 restart paperplane",
    "pm2:logs": "pm2 logs paperplane",
    "deploy": "npm run build && pm2 restart paperplane",
    "prisma:generate": "npx prisma generate",
    "prisma:push": "npx prisma db push"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.5",
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lavalink-client": "^2.10.2",
    "mongoose": "^9.7.4",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0"
  }
}
